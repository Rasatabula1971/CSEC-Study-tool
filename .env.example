# Copy this file to .env and update SSD_ROOT to your actual SSD drive letter.
# .env is gitignored — never commit it.

SSD_ROOT=D:\CSEC_AI_STUDY_PARTNER
DB_PATH=D:\CSEC_AI_STUDY_PARTNER\02_DATABASE\csec.sqlite
KB_ROOT=D:\CSEC_AI_STUDY_PARTNER\03_KNOWLEDGE_BASE
REPORTS_ROOT=D:\CSEC_AI_STUDY_PARTNER\04_REPORTS
OLLAMA_BASE=http://localhost:11434
MODEL_CHAT=llama3.2:3b
MODEL_EMBED=nomic-embed-text
EMBED_DIM=768

# Optional. Photo/image notes are OCR'd with Tesseract. By default the bundled
# copy at SSD_ROOT\Tesseract\tesseract.exe is auto-detected; set this only to
# point at a Tesseract binary elsewhere.
# TESSERACT_CMD=E:\CSEC_AI_STUDY_PARTNER\Tesseract\tesseract.exe

# Optional: set to 1 to enable Gemini cloud grading.
# Requires a valid GEMINI_API_KEY. Offline mode works without this.
CLOUD_MODE=0
GEMINI_API_KEY=
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.0-flash
# Optional: override the Gemini model used specifically for visual HTML generation.
# gemini-2.0-flash has an 8192 output-token limit shared with thinking tokens, which
# can truncate complex visuals. A model with a higher output limit (e.g.
# gemini-2.5-flash-preview-05-20) avoids truncation. Defaults to GEMINI_MODEL if unset.
# VISUAL_GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# Build-time only (PHASE: build). Lesson composition routes to Claude Sonnet via
# the Anthropic API on the BUILDER's machine. Never used at runtime / on the
# student's machine. Leave blank to fall back to Ollama (lower quality).
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# UI overhaul session 2. PIN for the Welcome page's discreet "Builder" link -- a
# light gate (single-student local app) so the student doesn't wander into the
# builder console by accident. Checked server-side; defaults to 1971 if unset.
BUILDER_PIN=1971
